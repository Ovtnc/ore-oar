# Database (PostgreSQL)
# Preferred: set these 5 values and let the app compose DATABASE_URL automatically.
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=oar_ore
POSTGRES_USER=oarore
POSTGRES_PASSWORD=change-this-password

# Optional direct connection string. If set, it overrides POSTGRES_*.
DATABASE_URL=postgresql://oarore:change-this-password@127.0.0.1:5432/oar_ore?schema=public

# Legacy Mongo -> PostgreSQL migration source (opsiyonel, sadece veri taşıma scripti için)
MIGRATION_MONGODB_URI=
MIGRATION_MONGODB_DB=oar-ore
# MIGRATION_TRUNCATE=1
# MIGRATION_ONLY=users,products,orders,support_requests,settings

# Auth
AUTH_SECRET=change-this-to-a-long-random-secret

# Admin access (email based)
ADMIN_NAME=Admin
ADMIN_PASSWORD=change-this-password
ADMIN_EMAIL=admin@example.com
ADMIN_ALLOWED_EMAIL=admin@example.com

# Default payment/shipping fallbacks (admin panel settings override these values)
NEXT_PUBLIC_IBAN=TR00 0000 0000 0000 0000 0000 00
NEXT_PUBLIC_WHATSAPP_NUMBER=905000000000
NEXT_PUBLIC_SHIPPING_FEE=120
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=2500

# App URL / payment automation
APP_BASE_URL=http://localhost:3000
N8N_PAYMENT_EVENT_WEBHOOK=
N8N_PAYMENT_EVENT_TOKEN=
N8N_PAYMENT_VERIFY_SECRET=

# Email transport (use Resend OR SMTP)
RESEND_API_KEY=
MAIL_FROM=Oar & Ore <no-reply@example.com>

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
